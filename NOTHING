	end)
	
	TabRow.Tab5.MouseButton1Click:Connect(function()
		switchTab(ContentFrame.Page_Config)
	end)
	
	TabRow.Tab6.MouseButton1Click:Connect(function()
		switchTab(ContentFrame.Page_Setting)
	end)
	
	-- RAINBOW TOGGLE
	local LeftPanel_Setting = ContentFrame.Page_Setting.ScrollArea.LeftPanel
	local SwitchBG = LeftPanel_Setting.Toggle_Rainbow.SwitchBG
	local Knob = SwitchBG.Knob
	local rainbowOn = false
	
	SwitchBG_ref = SwitchBG
	
	local function setSwitch(on)
		rainbowOn = on
		if on then
			startRainbow()
			TweenService:Create(Knob, TweenInfo.new(0.2), {
				Position = UDim2.new(1, -14, 0.5, 0)
			}):Play()
		else
			TweenService:Create(Knob, TweenInfo.new(0.2), {
				Position = UDim2.new(0, 2, 0.5, 0)
			}):Play()
			stopRainbow()
		end
	end
	
	SwitchBG.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or
			input.UserInputType == Enum.UserInputType.Touch then
			setSwitch(not rainbowOn)
		end
	end)
	
	-- MOONWALK TOGGLE
	local LeftPanel_Misc = ContentFrame.Page_Misc.ScrollArea.LeftPanel
	local MoonwalkSwitchBG = LeftPanel_Misc.Toggle_Moonwalk.SwitchBG
	local MoonwalkKnob = MoonwalkSwitchBG.Knob
	local MoonwalkScript = LeftPanel_Misc.Toggle_Moonwalk.MoonwalkScript
	local moonwalkOn = false
	
	local function setMoonwalkSwitch(on)
		moonwalkOn = on
		if on then
			MoonwalkScript.Disabled = false
			TweenService:Create(MoonwalkKnob, TweenInfo.new(0.2), {
				Position = UDim2.new(1, -14, 0.5, 0)
			}):Play()
			if not rainbowOn then
				TweenService:Create(MoonwalkSwitchBG, TweenInfo.new(0.2), {
					BackgroundColor3 = Color3.fromRGB(180, 0, 255)
				}):Play()
			end
		else
			MoonwalkScript.Disabled = true
			TweenService:Create(MoonwalkKnob, TweenInfo.new(0.2), {
				Position = UDim2.new(0, 2, 0.5, 0)
			}):Play()
			if not rainbowOn then
				TweenService:Create(MoonwalkSwitchBG, TweenInfo.new(0.2), {
					BackgroundColor3 = Color3.fromRGB(50, 50, 50)
				}):Play()
			end
		end
	end
	
	MoonwalkSwitchBG.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or
			input.UserInputType == Enum.UserInputType.Touch then
			setMoonwalkSwitch(not moonwalkOn)
		end
	end)
	
	-- CONFIG SYSTEM
	local configList = {}
	local autoloadConfig = nil
	local selectedConfig = nil
	
	local LeftPanel_Config = ContentFrame.Page_Config.ScrollArea.LeftPanel
	local InputConfigName = LeftPanel_Config.InputConfigName
	local ConfigListFrame = LeftPanel_Config.ConfigListFrame
	local Btn_SelectConfig = LeftPanel_Config.Btn_SelectConfig
	
	InputConfigName:GetPropertyChangedSignal("Text"):Connect(function()
		if #InputConfigName.Text > 15 then
			InputConfigName.Text = string.sub(InputConfigName.Text, 1, 15)
		end
	end)
	
	local function updateSelectBtn()
		if selectedConfig then
			Btn_SelectConfig.Text = selectedConfig
			Btn_SelectConfig.TextColor3 = Color3.fromRGB(0, 0, 0)
		else
			Btn_SelectConfig.Text = ". . ."
			Btn_SelectConfig.TextColor3 = Color3.fromRGB(100, 100, 100)
		end
	end
	
	local function getToggles()
		local data = {}
		for _, v in pairs(MainFrame:GetDescendants()) do
			if v.Name == "Box" and v:IsA("TextButton") then
				local isOn = v.BackgroundColor3 == Color3.fromRGB(255, 255, 255)
				data[v.Parent.Name] = isOn
			end
		end
		return data
	end
	
	local function applyToggles(data)
		for _, v in pairs(MainFrame:GetDescendants()) do
			if v.Name == "Box" and v:IsA("TextButton") then
				local path = v.Parent.Name
				if data[path] ~= nil then
					if data[path] then
						v.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
					else
						v.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
					end
				end
			end
		end
	end
	
	local function refreshConfigList()
		for _, v in pairs(ConfigListFrame:GetChildren()) do
			if v:IsA("TextButton") then
				v:Destroy()
			end
		end
	
		local index = 0
		for name, _ in pairs(configList) do
			local btn = Instance.new("TextButton")
			btn.Parent = ConfigListFrame
			btn.ZIndex = 99
			btn.Size = UDim2.new(1, 0, 0, 18)
			btn.Position = UDim2.new(0, 0, 0, index * 22)
			btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
			btn.BackgroundTransparency = 0.1
			btn.BorderSizePixel = 0
			btn.Text = name
			btn.TextColor3 = Color3.fromRGB(255, 255, 255)
			btn.Font = Enum.Font.Creepster
			btn.TextSize = 11
			btn.TextTruncate = Enum.TextTruncate.AtEnd
	
			local corner = Instance.new("UICorner")
			corner.CornerRadius = UDim.new(0, 4)
			corner.Parent = btn
	
			btn.MouseButton1Click:Connect(function()
				selectedConfig = name
				updateSelectBtn()
				ConfigListFrame.Visible = false
			end)
	
			index += 1
		end
	
		ConfigListFrame.Position = UDim2.new(0, 0, 0, 107)
		ConfigListFrame.Size = UDim2.new(1, 0, 0, math.min(index * 22, 132))
		ConfigListFrame.CanvasSize = UDim2.new(0, 0, 0, index * 22)
	end
	
	-- CREATE CONFIG
	LeftPanel_Config.Btn_CreateConfig.MouseButton1Click:Connect(function()
		local name = InputConfigName.Text
		if name == "" or name == nil then return end
		configList[name] = getToggles()
		selectedConfig = name
		updateSelectBtn()
		InputConfigName.Text = ""
		refreshConfigList()
	end)
	
	-- SELECT CONFIG
	Btn_SelectConfig.MouseButton1Click:Connect(function()
		refreshConfigList()
		ConfigListFrame.Visible = not ConfigListFrame.Visible
	end)
	
	-- LOAD CONFIG
	LeftPanel_Config.Btn_LoadConfig.MouseButton1Click:Connect(function()
		if not selectedConfig or not configList[selectedConfig] then return end
		applyToggles(configList[selectedConfig])
	end)
	
	-- OVERWRITE CONFIG
	LeftPanel_Config.Btn_OverwriteConfig.MouseButton1Click:Connect(function()
		if not selectedConfig then return end
		configList[selectedConfig] = getToggles()
	end)
	
	-- DELETE CONFIG
	LeftPanel_Config.Btn_DeleteConfig.MouseButton1Click:Connect(function()
		if not selectedConfig then return end
		configList[selectedConfig] = nil
		selectedConfig = nil
		updateSelectBtn()
		refreshConfigList()
	end)
	
	-- REFRESH LIST
	LeftPanel_Config.Btn_RefreshList.MouseButton1Click:Connect(function()
		refreshConfigList()
	end)
	
	-- SET AS AUTOLOAD
	LeftPanel_Config.Btn_SetAutoload.MouseButton1Click:Connect(function()
		if not selectedConfig then return end
		autoloadConfig = selectedConfig
	end)
	
	-- RESET AUTOLOAD
	LeftPanel_Config.Btn_ResetAutoload.MouseButton1Click:Connect(function()
		autoloadConfig = nil
	end)
	
	-- AUTOLOAD ON START
	if autoloadConfig and configList[autoloadConfig] then
		applyToggles(configList[autoloadConfig])
	end
end
coroutine.wrap(FAUK_fake_script)()
local function ESKAV_fake_script() -- Toggle_Moonwalk.MoonwalkScript 
	local script = Instance.new('LocalScript', Toggle_Moonwalk)

	--⛧ ⸸ — —〔 𝕻𝕽𝕴𝖁𝕬𝕿𝕰 𝕻𝕽𝕺𝕻𝕰𝕽𝕿𝖄 〕— — ⸸ ⛧
	
	if not game:IsLoaded() then
		game.Loaded:Wait()
	end
	
	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local CoreGui = game:GetService("CoreGui")
	local UserInputService = game:GetService("UserInputService")
	
	local LP = Players.LocalPlayer
	local Enabled = false
	local DragLocked = false
	
	--⛧ ⸸ — —〔 𝕽𝕺𝕿𝕬𝕿𝕴𝕺𝕹 𝕾𝕸𝕺𝕺𝕿𝕳𝕹𝕰𝕾𝕾 〕— — ⸸ ⛧
	
	local CurrentLook = nil
	local Smoothness = 0.20
	
	--⛧ ⸸ — —〔 𝕬𝕹𝕲𝕷𝕰 𝕬𝕮𝕮𝖀𝕸𝖀𝕷𝕬𝕿𝕴𝕺𝕹 𝖅𝕴𝕲𝖅𝕬𝕲 〕— — ⸸ ⛧
	
	local ZigAngle = 0
	local ZigMax = 40
	local ZigSpeed = 850
	local ZigReturnSpeed = 800
	local ZigDirection = 1
	local ZigSwitchDelay = 0.060
	local ZigTick = 0
	
	--⛧ ⸸ — —〔 𝕾𝕸𝕬𝕽𝕿 𝕽𝕺𝕿𝕬𝕿𝕰 𝕯𝕰𝕿𝕰𝕮𝕿 〕— — ⸸ ⛧
	
	local RotateReady = false
	
	--⛧ ⸸ — —〔 𝕬𝕹𝕬𝕷𝕺𝕲 𝕱𝕴𝖃 〕— — ⸸ ⛧
	
	local LastMoveDir = nil
	
	--⛧ ⸸ — —〔 𝖂𝕬𝕷𝕶 𝕱𝕰𝕰𝕷 〕— — ⸸ ⛧
	
	local MoveSlowdown = 0.82
	local MoveBlend = nil
	
	--⛧ ⸸ — —〔 𝕬-𝕯 𝕾𝕴𝕸𝖀𝕷𝕬𝕿𝕴𝕺𝕹 〕— — ⸸ ⛧
	
	local LastZigDir = 0
	local ZigStrafe = 0.45
	
	--⛧ ⸸ — —〔 𝕽𝕰𝕸𝕺𝖁𝕰 𝕺𝕷𝕯 〕— — ⸸ ⛧
	
	pcall(function()
		CoreGui:FindFirstChild("MoonwalkLogo"):Destroy()
	end)
	
	--⛧ ⸸ — —〔 𝕲𝖀𝕴 〕— — ⸸ ⛧
	
	local gui = Instance.new("ScreenGui")
	gui.Name = "MoonwalkLogo"
	gui.ResetOnSpawn = false
	gui.Parent = CoreGui
	
	--⛧ ⸸ — —〔 𝕲𝕰𝕿 𝖁𝕯 𝖀𝕴 〕— — ⸸ ⛧
	
	local original = LP.PlayerGui.Emotes.emotebut.emote
	
	--⛧ ⸸ — —〔 𝕸𝕬𝕴𝕹 𝖁𝕯 𝕭𝖀𝕿𝕿𝕺𝕹 〕— — ⸸ ⛧
	
	local main = original:Clone()
	main.Parent = gui
	
	main.Size = UDim2.new(0,68,0,68)
	main.Position = UDim2.new(0.5,277,0.35,-147)
	
	main.Active = true
	main.Selectable = false
	
	for _,v in pairs(main:GetDescendants()) do
		if v:IsA("ImageLabel") or v:IsA("ImageButton") then
			v.Image = ""
		end
	
		if v:IsA("TextLabel") or v:IsA("TextButton") then
			v.Text = ""
		end
	end
	
	--⛧ ⸸ — —〔 𝕭𝖀𝕿𝕿𝕺𝕹 . . . 〕— — ⸸ ⛧
	
	local btn = Instance.new("TextButton")
	btn.Parent = main
	
	btn.BackgroundTransparency = 1
	btn.Size = UDim2.new(1,0,1,0)
	
	btn.Text = ". . ."
	btn.Font = Enum.Font.Gotham
	
	btn.TextScaled = false
	btn.TextSize = 20
	
	btn.TextColor3 = Color3.fromRGB(255,255,255)
	
	btn.Active = true
	btn.Selectable = false
	btn.AutoButtonColor = false
	
	--⛧ ⸸ — —〔 𝕮𝖀𝕾𝕿𝕺𝕸 𝕯𝕽𝕬𝕲 𝕾𝖄𝕾𝕿𝕰𝕸 〕— — ⸸ ⛧
	
	local dragging = false
	local dragStart
	local startPos
	
	main.InputBegan:Connect(function(input)
		if DragLocked then return end
	
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
	
			dragging = true
			dragStart = input.Position
			startPos = main.Position
	
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (
			input.UserInputType == Enum.UserInputType.MouseMovement
				or input.UserInputType == Enum.UserInputType.Touch
			) then
	
			local delta = input.Position - dragStart
	
			main.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end)
	
	--⛧ ⸸ — —〔 𝕷𝕺𝕮𝕶 𝕭𝖀𝕿𝕿𝕺𝕹 〕— — ⸸ ⛧
	
	local lockBtn = Instance.new("TextButton")
	lockBtn.Parent = gui
	
	lockBtn.Size = UDim2.new(0,24,0,24)
	lockBtn.Position = UDim2.new(1,-50,1,-50)
	
	lockBtn.BackgroundTransparency = 1
	lockBtn.Text = "🔓"
	
	lockBtn.Font = Enum.Font.Gotham
	lockBtn.TextScaled = true
	
	lockBtn.TextColor3 = Color3.fromRGB(255,255,255)
	
	lockBtn.Active = true
	lockBtn.Selectable = false
	lockBtn.AutoButtonColor = false
	
	--⛧ ⸸ — —〔 𝖁𝕴𝕾𝖀𝕬𝕷 〕— — ⸸ ⛧
	
	local function updateVisual()
		if Enabled then
			btn.TextColor3 = Color3.fromRGB(0,0,0)
		else
			btn.TextColor3 = Color3.fromRGB(255,255,255)
		end
	end
	
	--⛧ ⸸ — —〔 𝕿𝕺𝕲𝕲𝕷𝕰 〕— — ⸸ ⛧
	
	btn.MouseButton1Click:Connect(function()
		Enabled = not Enabled
		updateVisual()
	end)
	
	main.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
	
			if not dragging then
				Enabled = not Enabled
				updateVisual()
			end
		end
	end)
	
	--⛧ ⸸ — —〔 𝕷𝕺𝕮𝕶 𝕾𝖄𝕾𝕿𝕰𝕸 〕— — ⸸ ⛧
	
	lockBtn.MouseButton1Click:Connect(function()
		DragLocked = not DragLocked
	
		if DragLocked then
			lockBtn.Text = "🔒"
		else
			lockBtn.Text = "🔓"
		end
	end)
	
	updateVisual()
	
	--⛧ ⸸ — —〔 𝕸𝕺𝕺𝕹𝖂𝕬𝕷𝕶 〕— — ⸸ ⛧
	
	RunService.RenderStepped:Connect(function(dt)
	
		local Char = LP.Character
		if not Char then return end
	
		local HRP = Char:FindFirstChild("HumanoidRootPart")
		local Hum = Char:FindFirstChildOfClass("Humanoid")
	
		if not HRP or not Hum then return end
	
		if Enabled and Hum.MoveDirection.Magnitude > 0 then
	
			Hum.AutoRotate = false
	
			local rawMove = Hum.MoveDirection
	
			--⛧ ⸸ — —〔 𝕱𝕰𝕰𝕷 𝕷𝕰𝕭𝕴𝕳 𝕭𝕰𝕽𝕬𝕿 〕— — ⸸ ⛧
	
			if MoveBlend then
				rawMove = MoveBlend:Lerp(rawMove, MoveSlowdown)
			end
	
			MoveBlend = rawMove
	
			--⛧ ⸸ — —〔 𝕱𝕴𝖃 𝕬𝕹𝕬𝕷𝕺𝕲 𝕸𝕺𝕭𝕴𝕷𝕰 〕— — ⸸ ⛧
	
			if LastMoveDir then
	
				local backwardDot =
					rawMove:Dot(-HRP.CFrame.LookVector)
	
				if backwardDot > 0.75 then
					rawMove = LastMoveDir:Lerp(rawMove, 0.72)
				else
					rawMove = LastMoveDir:Lerp(rawMove, 0.28)
				end
			end
	
			LastMoveDir = rawMove
	
			local moveDir = rawMove.Unit
			local targetLook = -moveDir
	
			if not CurrentLook then
				CurrentLook = HRP.CFrame.LookVector
				RotateReady = false
				ZigAngle = 0
				LastZigDir = 0
			end
	
			--⛧ ⸸ — —〔 𝕾𝕸𝕺𝕺𝕿𝕳 𝕽𝕺𝕿𝕬𝕿𝕰 〕— — ⸸ ⛧
	
			CurrentLook = CurrentLook:Lerp(targetLook, Smoothness)
	
			CurrentLook = Vector3.new(
				CurrentLook.X,
				0,
				CurrentLook.Z
			)
	
			if CurrentLook.Magnitude > 0 then
				CurrentLook = CurrentLook.Unit
			end
	
			--⛧ ⸸ — —〔 𝕽𝕺𝕿𝕬𝕿𝕰 𝕯𝕰𝕿𝕰𝕮𝕿 〕— — ⸸ ⛧
	
			local dot =
				CurrentLook:Dot(targetLook)
	
			if dot >= 0.985 then
				RotateReady = true
			end
	
			--⛧ ⸸ — —〔 𝕬𝕹𝕲𝕷𝕰 𝕬𝕮𝕮𝖀𝕸𝖀𝕷𝕬𝕿𝕴𝕺𝕹 〕— — ⸸ ⛧
	
			if RotateReady then
	
				ZigTick += dt
	
				if ZigTick >= ZigSwitchDelay then
					ZigTick = 0
					ZigDirection = -ZigDirection
					LastZigDir = ZigDirection
				end
	
				if LastZigDir == 0 then
					LastZigDir = ZigDirection
				end
	
				ZigAngle = math.clamp(
					ZigAngle + (ZigSpeed * dt * ZigDirection),
					-ZigMax,
					ZigMax
				)
	
			else
	
				LastZigDir = 0
	
				if ZigAngle > 0 then
					ZigAngle = math.max(
						ZigAngle - (ZigReturnSpeed * dt),
						0
					)
				elseif ZigAngle < 0 then
					ZigAngle = math.min(
						ZigAngle + (ZigReturnSpeed * dt),
						0
					)
				end
			end
	
			local pos = HRP.Position
	
			local baseCF = CFrame.lookAt(
				pos,
				pos + CurrentLook
			)
	
			local rightVec = baseCF.RightVector
			local strafeDir = rightVec * (LastZigDir * ZigStrafe)
			local strafedPos = pos + strafeDir * dt * (Hum.WalkSpeed or 16)
	
			--⛧ ⸸ — —〔 𝕾𝕴𝕸𝕻𝕬𝕹 𝕶𝕬𝕸𝕰𝕽𝕬 〕— — ⸸ ⛧
	
			local cam = workspace.CurrentCamera
			local camCF = cam.CFrame
	
			HRP.CFrame =
				CFrame.new(strafedPos) *
				CFrame.fromMatrix(
					Vector3.new(0, 0, 0),
					baseCF.RightVector,
					Vector3.new(0, 1, 0)
				) *
				CFrame.Angles(
					0,
					math.rad(ZigAngle),
					0
				)
	
			--⛧ ⸸ — —〔 𝕽𝕰𝕾𝕿𝕺𝕽𝕰 𝕶𝕬𝕸𝕰𝕽𝕬 〕— — ⸸ ⛧
	
			cam.CFrame = camCF
	
		else
	
			local Hum = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
	
			if Hum then
				Hum.AutoRotate = true
			end
	
			CurrentLook = nil
			RotateReady = false
			LastMoveDir = nil
			MoveBlend = nil
			ZigAngle = 0
			LastZigDir = 0
		end
	end)
end
