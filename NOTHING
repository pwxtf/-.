		end
		return switches
	end
	
	-- SIMPAN WARNA ASLI
	local savedTextColors = {}
	local savedDividerColors = {}
	local savedBorderColors = {}
	local savedSwitchColors = {}
	
	local function saveDefaultColors()
		savedTextColors = {}
		savedDividerColors = {}
		savedBorderColors = {}
		savedSwitchColors = {}
	
		for _, v in pairs(getAllTexts()) do
			savedTextColors[v] = v.TextColor3
		end
		for _, v in pairs(getAllDividers()) do
			savedDividerColors[v] = v.BackgroundColor3
		end
		for _, v in pairs(getAllBorderImages()) do
			savedBorderColors[v] = v.ImageColor3
		end
		for _, v in pairs(getAllSwitches()) do
			savedSwitchColors[v] = v.BackgroundColor3
		end
	end
	
	-- RAINBOW
	local RunService = game:GetService("RunService")
	local rainbowConnection = nil
	local rainbowHue = 0.66
	local SwitchBG_ref = nil
	
	local TweenService = game:GetService("TweenService")
	
	local function startRainbow()
		saveDefaultColors()
		rainbowConnection = RunService.Heartbeat:Connect(function(dt)
			rainbowHue = (rainbowHue + dt * 0.05) % 1
			local color = Color3.fromHSV(rainbowHue, 0.6, 1)
			for _, v in pairs(getAllTexts()) do
				v.TextColor3 = color
			end
			for _, v in pairs(getAllDividers()) do
				v.BackgroundColor3 = color
			end
			for _, v in pairs(getAllBorderImages()) do
				v.ImageColor3 = color
			end
			for _, v in pairs(getAllSwitches()) do
				v.BackgroundColor3 = color
			end
		end)
	end
	
	local function stopRainbow()
		if rainbowConnection then
			rainbowConnection:Disconnect()
			rainbowConnection = nil
		end
		for v, color in pairs(savedTextColors) do
			if v and v.Parent then
				v.TextColor3 = color
			end
		end
		for v, color in pairs(savedDividerColors) do
			if v and v.Parent then
				v.BackgroundColor3 = color
			end
		end
		for v, color in pairs(savedBorderColors) do
			if v and v.Parent then
				v.ImageColor3 = color
			end
		end
		for v, color in pairs(savedSwitchColors) do
			if v and v.Parent then
				v.BackgroundColor3 = color
			end
		end
	end
	
	-- TAB SWITCHING
	local function switchTab(page)
		for _, p in pairs(ContentFrame:GetChildren()) do
			if p:IsA("Frame") then
				p.Visible = false
			end
		end
		page.Visible = true
	end
	
