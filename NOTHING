local function IYFLV_fake_script() -- SynthUI.UIScript 
	local script = Instance.new('LocalScript', SynthUI)

	local MainFrame = script.Parent.MainFrame
	local ContentFrame = MainFrame.ContentFrame
	local TabRow = MainFrame.TabRow
	
	-- TOGGLE FUNCTION
	local function SetupToggle(toggle)
		local box = toggle.Box
		local isChecked = false
		box.MouseButton1Click:Connect(function()
			isChecked = not isChecked
			if isChecked then
				box.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
			else
				box.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
			end
		end)
	end
	
	-- SLIDER FUNCTION
	local function SetupSlider(slider, minVal, maxVal, defaultVal)
		local track = slider.Track
		local fill = track.Fill
		local value = slider.Value
		local dragging = false
	
		local function updateSlider(input)
			local trackPos = track.AbsolutePosition.X
			local trackSize = track.AbsoluteSize.X
			local relative = math.clamp((input.Position.X - trackPos) / trackSize, 0, 1)
			local val = math.floor(minVal + (maxVal - minVal) * relative)
			fill.Size = UDim2.new(relative, 0, 1, 0)
			value.Text = val .. "/" .. maxVal
		end
	
		local defaultRelative = (defaultVal - minVal) / (maxVal - minVal)
		fill.Size = UDim2.new(defaultRelative, 0, 1, 0)
		value.Text = defaultVal .. "/" .. maxVal
	
		track.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or
				input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				updateSlider(input)
			end
		end)
	
		track.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or
				input.UserInputType == Enum.UserInputType.Touch then
				dragging = false
			end
		end)
	
		game:GetService("UserInputService").InputChanged:Connect(function(input)
			if dragging then
				if input.UserInputType == Enum.UserInputType.MouseMovement or
					input.UserInputType == Enum.UserInputType.Touch then
					updateSlider(input)
				end
			end
		end)
	end
	
	-- KUMPULIN SEMUA TEXT
	local function getAllTexts()
		local texts = {}
		for _, v in pairs(MainFrame:GetDescendants()) do
			if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
				table.insert(texts, v)
			end
		end
		return texts
	end
	
	-- KUMPULIN SEMUA DIVIDER
	local function getAllDividers()
		local dividers = {}
		for _, v in pairs(MainFrame:GetDescendants()) do
			if v:IsA("Frame") and v.Name == "Divider" then
				table.insert(dividers, v)
			end
		end
		return dividers
	end
	
	-- KUMPULIN SEMUA BORDER IMAGELABEL
	local function getAllBorderImages()
		local borders = {}
		for _, v in pairs(MainFrame:GetDescendants()) do
			if v:IsA("ImageLabel") and v.Name == "Border" then
				table.insert(borders, v)
			end
		end
		return borders
	end
	
	-- KUMPULIN SEMUA SWITCHBG
	local function getAllSwitches()
		local switches = {}
		for _, v in pairs(MainFrame:GetDescendants()) do
			if v:IsA("Frame") and v.Name == "SwitchBG" then
				table.insert(switches, v)
			end
		end
		return switches
	end
	
	-- SIMPAN WARNA ASLI
	local savedTextColors = {}
	local savedDividerColors = {}
	local savedBorderColors = {}
	local savedSwitchColors = {}
	
	local function saveDefaultColors()
		savedTextColors = {}
		savedDividerColors = {}
		savedBorderColors = {}
		savedSwitchColors = {}
	
		for _, v in pairs(getAllTexts()) do
			savedTextColors[v] = v.TextColor3
		end
		for _, v in pairs(getAllDividers()) do
			savedDividerColors[v] = v.BackgroundColor3
		end
		for _, v in pairs(getAllBorderImages()) do
			savedBorderColors[v] = v.ImageColor3
		end
		for _, v in pairs(getAllSwitches()) do
			savedSwitchColors[v] = v.BackgroundColor3
		end
	end
	
	-- RAINBOW
	local RunService = game:GetService("RunService")
	local rainbowConnection = nil
	local rainbowHue = 0.66
	local SwitchBG_ref = nil
	
	local TweenService = game:GetService("TweenService")
	
	local function startRainbow()
		saveDefaultColors()
		rainbowConnection = RunService.Heartbeat:Connect(function(dt)
			rainbowHue = (rainbowHue + dt * 0.05) % 1
			local color = Color3.fromHSV(rainbowHue, 0.6, 1)
			for _, v in pairs(getAllTexts()) do
				v.TextColor3 = color
			end
			for _, v in pairs(getAllDividers()) do
				v.BackgroundColor3 = color
			end
			for _, v in pairs(getAllBorderImages()) do
				v.ImageColor3 = color
			end
			for _, v in pairs(getAllSwitches()) do
				v.BackgroundColor3 = color
			end
		end)
	end
	
	local function stopRainbow()
		if rainbowConnection then
			rainbowConnection:Disconnect()
			rainbowConnection = nil
		end
		for v, color in pairs(savedTextColors) do
			if v and v.Parent then
				v.TextColor3 = color
			end
		end
		for v, color in pairs(savedDividerColors) do
			if v and v.Parent then
				v.BackgroundColor3 = color
			end
		end
		for v, color in pairs(savedBorderColors) do
			if v and v.Parent then
				v.ImageColor3 = color
			end
		end
		for v, color in pairs(savedSwitchColors) do
			if v and v.Parent then
				v.BackgroundColor3 = color
			end
		end
	end
	
	-- TAB SWITCHING
	local function switchTab(page)
		for _, p in pairs(ContentFrame:GetChildren()) do
			if p:IsA("Frame") then
				p.Visible = false
			end
		end
		page.Visible = true
	end
	
	TabRow.Tab1.MouseButton1Click:Connect(function()
		switchTab(ContentFrame.Page_AutoParry)
	end)
	
	TabRow.Tab2.MouseButton1Click:Connect(function()
		switchTab(ContentFrame.Page_SilentAim)
	end)
	
	TabRow.Tab3.MouseButton1Click:Connect(function()
		switchTab(ContentFrame.Page_Aimlock)
	end)
	
	TabRow.Tab4.MouseButton1Click:Connect(function()
		switchTab(ContentFrame.Page_Misc)
	end)
	
	TabRow.Tab5.MouseButton1Click:Connect(function()
		switchTab(ContentFrame.Page_Config)
	end)
	
	TabRow.Tab6.MouseButton1Click:Connect(function()
		switchTab(ContentFrame.Page_Setting)
	end)
	
	-- RAINBOW TOGGLE
	local LeftPanel_Setting = ContentFrame.Page_Setting.ScrollArea.LeftPanel
	local SwitchBG = LeftPanel_Setting.Toggle_Rainbow.SwitchBG
	local Knob = SwitchBG.Knob
	local rainbowOn = false
	
	SwitchBG_ref = SwitchBG
	
	local function setSwitch(on)
		rainbowOn = on
		if on then
			startRainbow()
			TweenService:Create(Knob, TweenInfo.new(0.2), {
				Position = UDim2.new(1, -14, 0.5, 0)
			}):Play()
		else
			TweenService:Create(Knob, TweenInfo.new(0.2), {
				Position = UDim2.new(0, 2, 0.5, 0)
			}):Play()
			stopRainbow()
		end
	end
	
	SwitchBG.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or
			input.UserInputType == Enum.UserInputType.Touch then
			setSwitch(not rainbowOn)
		end
	end)
	
	-- NOTIF SYSTEM
	local NotifFrame = MainFrame.NotifFrame
	local NotifText = NotifFrame.NotifText
	local notifThread = nil
	
	local function showNotif(text)
		if notifThread then
			task.cancel(notifThread)
			notifThread = nil
		end
		NotifText.Text = text
		NotifFrame.Visible = true
		notifThread = task.delay(2, function()
			NotifFrame.Visible = false
		end)
	end
	
	-- CONFIG SYSTEM PERMANEN
	local HttpService = game:GetService("HttpService")
	local configFolder = "SynthConfigs/"
	local autoloadFile = configFolder .. "autoload.json"
	
	local function ensureFolder()
		if not isfolder(configFolder) then
			makefolder(configFolder)
		end
	end
	
	local function saveConfig(name, data)
		ensureFolder()
		writefile(configFolder .. name .. ".json", HttpService:JSONEncode(data))
	end
	
	local function loadConfigFile(name)
		local path = configFolder .. name .. ".json"
		if isfile(path) then
			return HttpService:JSONDecode(readfile(path))
		end
		return nil
	end
	
	local function deleteConfigFile(name)
		local path = configFolder .. name .. ".json"
		if isfile(path) then
			delfile(path)
		end
	end
	
	local function getConfigFiles()
		ensureFolder()
		local files = listfiles(configFolder)
		local names = {}
		for _, f in pairs(files) do
			local name = f:gsub(configFolder, ""):gsub("%.json", "")
			if name ~= "autoload" then
				table.insert(names, name)
			end
		end
		return names
	end
	
	local configList = {}
	local selectedConfig = nil
	
	local LeftPanel_Config = ContentFrame.Page_Config.ScrollArea.LeftPanel
	local InputConfigName = LeftPanel_Config.InputConfigName
	local ConfigListFrame = LeftPanel_Config.ConfigListFrame
	local Btn_SelectConfig = LeftPanel_Config.Btn_SelectConfig
	
	InputConfigName:GetPropertyChangedSignal("Text"):Connect(function()
		if #InputConfigName.Text > 15 then
			InputConfigName.Text = string.sub(InputConfigName.Text, 1, 15)
		end
	end)
	
	local function updateSelectBtn()
		if selectedConfig then
			Btn_SelectConfig.Text = selectedConfig
			Btn_SelectConfig.TextColor3 = Color3.fromRGB(255, 255, 255)
		else
			Btn_SelectConfig.Text = ". . ."
			Btn_SelectConfig.TextColor3 = Color3.fromRGB(100, 100, 100)
		end
	end
	
	local function getToggles()
		local data = {}
		data["__rainbow__"] = rainbowOn
	
		for _, v in pairs(MainFrame:GetDescendants()) do
			if v:IsA("Frame") and v.Name == "SwitchBG" then
				local knob = v:FindFirstChild("Knob")
				if knob then
					local isOn = knob.Position.X.Scale > 0.5
					local toggleName = v.Parent.Name
					data[toggleName] = isOn
				end
			end
		end
		return data
	end
	
	local function applyToggles(data)
		if data["__rainbow__"] ~= nil then
			if data["__rainbow__"] ~= rainbowOn then
				setSwitch(data["__rainbow__"])
			end
		end
	
		for _, v in pairs(MainFrame:GetDescendants()) do
			if v:IsA("Frame") and v.Name == "SwitchBG" then
				local knob = v:FindFirstChild("Knob")
				local toggleName = v.Parent.Name
				if toggleName ~= "Toggle_Rainbow" then
					if knob and data[toggleName] ~= nil then
						local on = data[toggleName]
						if on then
							knob.Position = UDim2.new(1, -14, 0.5, 0)
							if not rainbowOn then
								v.BackgroundColor3 = Color3.fromRGB(180, 0, 255)
							end
						else
							knob.Position = UDim2.new(0, 2, 0.5, 0)
							if not rainbowOn then
								v.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
							end
						end
					end
				end
			end
		end
	end
	
	local function refreshConfigList()
		for _, v in pairs(ConfigListFrame:GetChildren()) do
			if v:IsA("TextButton") then
				v:Destroy()
			end
		end
	
		local names = getConfigFiles()
		local index = 0
		for _, name in pairs(names) do
			local btn = Instance.new("TextButton")
			btn.Parent = ConfigListFrame
			btn.ZIndex = 99
			btn.Size = UDim2.new(1, 0, 0, 18)
			btn.Position = UDim2.new(0, 0, 0, index * 22)
			btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
			btn.BackgroundTransparency = 0.1
			btn.BorderSizePixel = 0
			btn.AutoButtonColor = false
			btn.Text = name
			btn.TextColor3 = Color3.fromRGB(255, 255, 255)
			btn.Font = Enum.Font.Creepster
			btn.TextSize = 11
			btn.TextTruncate = Enum.TextTruncate.AtEnd
	
			local corner = Instance.new("UICorner")
			corner.CornerRadius = UDim.new(0, 4)
			corner.Parent = btn
	
			btn.MouseButton1Click:Connect(function()
				selectedConfig = name
				updateSelectBtn()
				ConfigListFrame.Visible = false
			end)
	
			index += 1
		end
	
		ConfigListFrame.Position = UDim2.new(0, 0, 0, 107)
		ConfigListFrame.Size = UDim2.new(1, 0, 0, math.min(index * 22, 132))
		ConfigListFrame.CanvasSize = UDim2.new(0, 0, 0, index * 22)
	end
	
	-- CREATE CONFIG
	LeftPanel_Config.Btn_CreateConfig.MouseButton1Click:Connect(function()
		local name = InputConfigName.Text
		if name == "" or name == nil then return end
		local data = getToggles()
		saveConfig(name, data)
		configList[name] = data
		selectedConfig = name
		updateSelectBtn()
		InputConfigName.Text = ""
		task.wait(0.1)
		refreshConfigList()
		showNotif("Config saved!")
	end)
	
	-- SELECT CONFIG
	Btn_SelectConfig.MouseButton1Click:Connect(function()
		refreshConfigList()
		ConfigListFrame.Visible = not ConfigListFrame.Visible
	end)
	
	-- LOAD CONFIG
	LeftPanel_Config.Btn_LoadConfig.MouseButton1Click:Connect(function()
		if not selectedConfig then return end
		local data = loadConfigFile(selectedConfig)
		if data then
			applyToggles(data)
			showNotif("Config loaded!")
		end
	end)
	
	-- OVERWRITE CONFIG
	LeftPanel_Config.Btn_OverwriteConfig.MouseButton1Click:Connect(function()
		if not selectedConfig then return end
		local data = getToggles()
		saveConfig(selectedConfig, data)
		configList[selectedConfig] = data
		showNotif("Config updated!")
	end)
	
	-- DELETE CONFIG
	LeftPanel_Config.Btn_DeleteConfig.MouseButton1Click:Connect(function()
		if not selectedConfig then return end
		deleteConfigFile(selectedConfig)
		configList[selectedConfig] = nil
		selectedConfig = nil
		updateSelectBtn()
		refreshConfigList()
		showNotif("Config deleted!")
	end)
	
	-- REFRESH LIST
	LeftPanel_Config.Btn_RefreshList.MouseButton1Click:Connect(function()
		refreshConfigList()
		showNotif("List refreshed!")
	end)
	
	-- SET AS AUTOLOAD
	LeftPanel_Config.Btn_SetAutoload.MouseButton1Click:Connect(function()
		if not selectedConfig then return end
		ensureFolder()
		writefile(autoloadFile, HttpService:JSONEncode({name = selectedConfig}))
		showNotif("Autoload set!")
	end)
	
	-- RESET AUTOLOAD
	LeftPanel_Config.Btn_ResetAutoload.MouseButton1Click:Connect(function()
		if isfile(autoloadFile) then
			delfile(autoloadFile)
		end
		showNotif("Autoload reset!")
	end)
	
	-- AUTOLOAD ON START
	task.spawn(function()
		task.wait(1)
		ensureFolder()
		if isfile(autoloadFile) then
			local data = HttpService:JSONDecode(readfile(autoloadFile))
			if data and data.name then
				local configData = loadConfigFile(data.name)
				if configData then
					selectedConfig = data.name
					updateSelectBtn()
					applyToggles(configData)
					showNotif("Autoload: " .. data.name)
				end
			end
		end
		refreshConfigList()
	end)
end
coroutine.wrap(IYFLV_fake_script)()
